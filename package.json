{
  "name": "mod-revert",
  "version": "1.0.0",
  "description": "Mod INI Revert Tool - Restore mod.ini from backup files",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "dist": "electron-builder --win",
    "pack": "electron-builder --dir"
  },
  "build": {
    "productName": "Mod Revert Tool",
    "appId": "com.tsukiamaoto.modrevert",
    "win": {
      "target": ["nsis", "portable"]
    },
    "directories": {
      "output": "release"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^35.2.1",
    "electron-builder": "^26.8.1"
  }
}
